{
  "name": "server",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch ./src/server.ts",
    "start": "node --import @swc-node/register/esm-register ./src/server.ts",
    "build": "rimraf ./dist && tsgo",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "check-types": "tsgo --noEmit",
    "lint": "eslint . --fix",
    "prettify": "prettier --write ./src/",
    "test": "vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:ui": "NODE_ENV=test vitest --ui"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "prettier": "@startername/prettier-config",
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.23",
    "@hono/node-server": "^2.0.8",
    "@hono/standard-validator": "0.2.3",
    "@hono/tsyringe": "^1.0.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@startername/enumwaii": "workspace:*",
    "@startername/common": "workspace:*",
    "@startername/server-contract": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "hono": "catalog:",
    "hono-openapi": "1.3.1",
    "ioredis": "5.11.1",
    "lodash-es": "catalog:",
    "pg": "^8.16.3",
    "reflect-metadata": "0.2.2",
    "safe-stable-stringify": "2.5.0",
    "tsyringe": "4.10.0",
    "winston": "3.19.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@startername/eslint-config": "workspace:*",
    "@startername/prettier-config": "workspace:*",
    "@swc-node/register": "catalog:",
    "@swc/core": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.15.5",
    "@typescript/native-preview": "catalog:",
    "@vitest/ui": "catalog:",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  }
}
