{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "../..",
    "paths": {
      "@~/*": ["./src/*"],
      "@startername/common/*": ["../../packages/common/src/*"],
      "@startername/server-contract/*": ["../../packages/server-contract/src/*"]
    },
    "outDir": "./dist",
    "types": ["node", "vitest"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "files": ["../../packages/common/src/globals.d.ts"],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "test/**/*.ts", "test/**/*.tsx"]
}
