{
  "name": "@startername/enumwaii",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch --no-clean",
    "build": "tsdown",
    "check-types": "tsgo --noEmit",
    "lint": "eslint . --fix",
    "prettify": "prettier --write ./src/ ./test/",
    "test": "vitest run",
    "prepare": "tsdown"
  },
  "prettier": "@startername/prettier-config",
  "devDependencies": {
    "@startername/eslint-config": "workspace:*",
    "@startername/prettier-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "8.63.0",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "dependencies": {
    "@typescript-eslint/utils": "8.58.0",
    "zod": "catalog:"
  }
}
