{
  "name": "startername",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose -f ./docker-compose.dev.yml --profile postgres up -d --wait && pnpm --parallel --filter=server --filter=web --filter=@startername/common --filter=@startername/server-contract run dev",
    "build": "pnpm --recursive run build",
    "test": "pnpm --recursive --stream run test",
    "check-types": "pnpm --recursive --stream --no-bail run check-types",
    "prettify": "pnpm --recursive --stream run prettify",
    "prettier": "pnpm run prettify",
    "dev:web": "pnpm --filter=web run dev",
    "dev:server": "pnpm --filter=server run dev",
    "dev:common": "pnpm --filter=@startername/common run dev",
    "dev:server-contract": "pnpm --filter=@startername/server-contract run dev",
    "db:generate": "pnpm --filter=server run db:generate",
    "db:migrate": "pnpm --filter=server run db:migrate",
    "db:push": "pnpm --filter=server run db:push",
    "db:studio": "pnpm --filter=server run db:studio",
    "lint": "pnpm --recursive --stream run lint",
    "lint:fix": "pnpm run lint",
    "verify": "tsx scripts/verify.ts",
    "clean:modules": "tsx scripts/clean.ts",
    "prepare": "husky",
    "commit": "cz",
    "build:deps": "pnpm --filter=@startername/common run build && pnpm --filter=@startername/server-contract run build",
    "update:workspaces": "pnpm update --interactive --recursive"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "commitizen": "4.3.2",
    "cz-git": "1.13.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "rimraf": "6.1.3",
    "tsx": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "czConfig": "./cz.config.cjs"
    }
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "24.13.0",
    "pnpm": ">=10.0.0"
  }
}
