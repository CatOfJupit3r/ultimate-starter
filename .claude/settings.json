{
  "permissions": {
    "allow": [
      "Bash(pnpm run *)",
      "Bash(pnpm --filter * run *)",
      "Bash(pnpm --filter * lint *)",
      "Bash(pnpm --filter * check-types *)",
      "Bash(pnpm --filter * test *)",

      "Bash(pnpm exec tsc *)",
      "Bash(pnpm exec eslint *)",
      "Bash(pnpm exec prettier *)",
      "Bash(pnpm exec vitest *)",

      "Bash(rg *)",

      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git blame *)",
      "Bash(git stash list)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list *)",
      "Bash(git branch -a *)",
      "Bash(git branch -vv *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(del *)",
      "Bash(rmdir *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(pnpm publish *)",
      "Bash(npm publish *)"
    ]
  }
}
